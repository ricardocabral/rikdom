{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/rikdom/schema/snapshot.schema.json",
  "title": "Rikdom Snapshot",
  "description": "One line from snapshots.jsonl.",
  "type": "object",
  "required": [
    "timestamp",
    "base_currency",
    "totals"
  ],
  "additionalProperties": false,
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "base_currency": {
      "type": "string",
      "pattern": "^[A-Z]{3}$"
    },
    "totals": {
      "type": "object",
      "required": ["portfolio_value_base", "by_asset_class"],
      "additionalProperties": false,
      "description": "Look-through breakdowns (by_region/by_currency/by_duration/by_liquidity_tier) follow economic_exposure precedence: holding.economic_exposure > asset_type.economic_exposure. Holdings without exposure data fall into the '__unclassified__' bucket so coverage gaps remain visible. As a pragmatic fallback, by_currency uses holdings[].market_value.currency when no exposure is declared.",
      "properties": {
        "portfolio_value_base": {
          "type": "number"
        },
        "by_asset_class": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        },
        "by_region": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "by_currency": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "by_duration": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        },
        "by_liquidity_tier": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
