{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/rikdom/schema/portfolio.schema.json",
  "title": "Rikdom Portfolio",
  "description": "Portable long-term portfolio schema focused on readability, extensibility and deterministic imports.",
  "type": "object",
  "required": [
    "schema_version",
    "schema_uri",
    "profile",
    "settings",
    "asset_type_catalog",
    "holdings"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Semantic version of this schema profile.",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "schema_uri": {
      "type": "string",
      "description": "Canonical URI for this schema contract and compatibility policy."
    },
    "profile": {
      "type": "object",
      "required": ["portfolio_id", "owner_kind", "display_name"],
      "additionalProperties": false,
      "properties": {
        "portfolio_id": {
          "type": "string"
        },
        "owner_kind": {
          "type": "string",
          "enum": ["person", "company", "family_office", "trust", "other"]
        },
        "display_name": {
          "type": "string"
        },
        "country": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "settings": {
      "type": "object",
      "required": ["base_currency"],
      "additionalProperties": false,
      "properties": {
        "base_currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "timezone": {
          "type": "string"
        },
        "country_context": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        }
      }
    },
    "asset_type_catalog": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/AssetTypeDefinition"
      }
    },
    "holdings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Holding"
      }
    },
    "activities": {
      "type": "array",
      "description": "Immutable import/events ledger. Derived projections should be computed from this stream.",
      "items": {
        "$ref": "#/$defs/Activity"
      }
    },
    "operations": {
      "type": "object",
      "description": "Optional operational task registry and immutable occurrence ledger for recurring portfolio work.",
      "additionalProperties": false,
      "properties": {
        "task_catalog": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/OperationalTask"
          }
        },
        "task_events": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/OperationalTaskEvent"
          }
        }
      }
    },
    "projections": {
      "type": "object",
      "description": "Optional derived projections (positions, performance, tax lots).",
      "additionalProperties": true
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "extensions": {
      "type": "object",
      "description": "Namespace for custom long-term fields to avoid breaking core compatibility.",
      "additionalProperties": true
    }
  },
  "$defs": {
    "Money": {
      "type": "object",
      "required": ["amount", "currency"],
      "additionalProperties": false,
      "properties": {
        "amount": {
          "type": "number"
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "scale": {
          "type": "integer",
          "minimum": 0,
          "description": "Optional decimal scale used by importer source."
        },
        "precision": {
          "type": "integer",
          "minimum": 0,
          "description": "Optional significant precision marker from importer source."
        }
      }
    },
    "InstrumentAttributeDefinition": {
      "type": "object",
      "required": ["id", "label", "value_type"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "label": {
          "type": "string"
        },
        "value_type": {
          "type": "string",
          "enum": ["string", "integer", "number", "boolean"]
        },
        "required": {
          "type": "boolean",
          "default": false
        },
        "description": {
          "type": "string"
        },
        "enum": {
          "type": "array",
          "items": {
            "type": ["string", "integer", "number", "boolean"]
          }
        },
        "unit": {
          "type": "string"
        }
      }
    },
    "AssetTypeDefinition": {
      "type": "object",
      "required": ["id", "label", "asset_class"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "label": {
          "type": "string"
        },
        "asset_class": {
          "type": "string",
          "description": "Top-level aggregation class.",
          "enum": [
            "stocks",
            "reits",
            "funds",
            "real_estate",
            "cash_equivalents",
            "digital_assets",
            "cryptocurrencies",
            "private_equity",
            "debt",
            "other"
          ]
        },
        "availability": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "countries": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^[A-Z]{2}$"
              }
            },
            "notes": {
              "type": "string"
            }
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "instrument_attributes": {
          "type": "array",
          "description": "Per-asset-type attribute schema for instrument-specific fields.",
          "items": {
            "$ref": "#/$defs/InstrumentAttributeDefinition"
          }
        }
      }
    },
    "Holding": {
      "type": "object",
      "required": [
        "id",
        "asset_type_id",
        "label",
        "market_value"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "asset_type_id": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "label": {
          "type": "string"
        },
        "jurisdiction": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "country": {
              "type": "string",
              "pattern": "^[A-Z]{2}$"
            }
          }
        },
        "identifiers": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "ticker": { "type": "string" },
            "isin": { "type": "string" },
            "provider_account_id": { "type": "string" },
            "wallet": { "type": "string" }
          }
        },
        "quantity": {
          "type": "number"
        },
        "unit_cost": {
          "$ref": "#/$defs/Money"
        },
        "market_value": {
          "$ref": "#/$defs/Money"
        },
        "as_of": {
          "type": "string",
          "format": "date-time"
        },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "source_system": { "type": "string" },
            "source_ref": { "type": "string" },
            "import_run_id": { "type": "string" },
            "idempotency_key": { "type": "string" },
            "ingested_at": { "type": "string", "format": "date-time" },
            "raw_payload_ref": { "type": "string" }
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "instrument_attributes": {
          "type": "object",
          "description": "Instrument-specific values keyed by ids declared in asset_type_catalog[].instrument_attributes.",
          "additionalProperties": {
            "type": ["string", "integer", "number", "boolean"]
          }
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "Activity": {
      "type": "object",
      "required": [
        "id",
        "event_type",
        "status",
        "effective_at"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "event_type": {
          "type": "string",
          "enum": [
            "buy",
            "sell",
            "dividend",
            "interest",
            "fee",
            "transfer_in",
            "transfer_out",
            "split",
            "income",
            "reimbursement",
            "other"
          ]
        },
        "subtype": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["pending", "posted", "cancelled"]
        },
        "effective_at": {
          "type": "string",
          "format": "date-time"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "source_system": { "type": "string" },
        "source_ref": { "type": "string" },
        "import_run_id": { "type": "string" },
        "ingested_at": {
          "type": "string",
          "format": "date-time"
        },
        "idempotency_key": { "type": "string" },
        "asset_type_id": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "instrument": {
          "type": "object",
          "additionalProperties": true
        },
        "quantity": {
          "type": "number"
        },
        "money": {
          "$ref": "#/$defs/Money"
        },
        "fees": {
          "$ref": "#/$defs/Money"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "CadenceRule": {
      "type": "object",
      "required": ["frequency"],
      "additionalProperties": false,
      "properties": {
        "frequency": {
          "type": "string",
          "enum": ["monthly", "quarterly", "yearly", "custom"]
        },
        "interval": {
          "type": "integer",
          "minimum": 1,
          "description": "Repeat interval for fixed-frequency cadences. Example: every 2 months."
        },
        "by_month_day": {
          "type": "integer",
          "minimum": 1,
          "maximum": 31
        },
        "by_month": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1,
            "maximum": 12
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "due_timezone": {
          "type": "string"
        },
        "rrule": {
          "type": "string",
          "description": "Optional RFC 5545 RRULE for custom schedules."
        }
      }
    },
    "OperationalTask": {
      "type": "object",
      "required": ["id", "label", "category", "status", "cadence"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "label": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": [
            "rebalancing",
            "tax",
            "reporting",
            "compliance",
            "cash_management",
            "risk_review",
            "planning",
            "other"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["active", "paused", "retired"]
        },
        "cadence": {
          "$ref": "#/$defs/CadenceRule"
        },
        "first_due_at": {
          "type": "string",
          "format": "date-time"
        },
        "next_due_at": {
          "type": "string",
          "format": "date-time"
        },
        "last_completed_at": {
          "type": "string",
          "format": "date-time"
        },
        "last_event_id": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "OperationalTaskEvent": {
      "type": "object",
      "required": ["id", "task_id", "event_type", "occurred_at"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "task_id": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$"
        },
        "event_type": {
          "type": "string",
          "enum": ["scheduled", "completed", "skipped", "cancelled", "reopened", "noted"]
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        },
        "period_start": {
          "type": "string",
          "format": "date-time"
        },
        "period_end": {
          "type": "string",
          "format": "date-time"
        },
        "performed_by": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "source_system": { "type": "string" },
        "source_ref": { "type": "string" },
        "import_run_id": { "type": "string" },
        "idempotency_key": { "type": "string" },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
